generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//// ENUMS ////

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  EXPIRED
  BLOCKED
}

enum UserRole {
  ADMIN
  NUTRITIONIST
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

//// MODELS ////

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(NUTRITIONIST)

  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime?

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  firstName     String
  lastName      String
  sex           Sex
  birthDate     DateTime
  activityLevel ActivityLevel

  measurements Measurement[]
  results      Result[]
  assessments  Assessment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Measurement {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  weightKg Float
  heightCm Float
  waistCm  Float?

  measuredAt DateTime

  createdAt DateTime @default(now())
}

model Result {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  bmi      Float
  bmiClass String
  tdeeKcal Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------
// 1. CATÁLOGOS FORMALES (Diccionarios base de la aplicación)
// ----------------------------------------------------------------------

enum MeasurementGroup {
  BASIC
  COMPOSITION
  SKINFOLD
  GIRTH
  CLINICAL_MARKER
}

enum MetricCategory {
  COMPOSITION
  INDEX
  DIAGNOSTIC
  ENERGY_REQUIREMENT
}

model MeasurementDefinition {
  id          String           @id
  group       MeasurementGroup
  name        String
  unit        String?
  description String?
  isActive    Boolean          @default(true)

  records MeasurementRecord[]
}

model MetricDefinition {
  id          String         @id
  name        String
  category    MetricCategory
  description String?
  isActive    Boolean        @default(true)

  results CalculatedResult[]
}

// ----------------------------------------------------------------------
// 2. NÚCLEO TRANSACCIONAL (Evaluación)
// ----------------------------------------------------------------------

enum AssessmentStatus {
  DRAFT
  COMPLETED
  ARCHIVED
}

model Assessment {
  id        String           @id @default(uuid())
  patientId String
  patient   Patient          @relation(fields: [patientId], references: [id])
  date      DateTime
  status    AssessmentStatus @default(DRAFT)

  ageAtAssessmentMonths Int?
  populationGroup       String?
  specialProfile        String?
  clinicalProtocol      String?
  protocolVersion       String?

  measurements MeasurementRecord[]
  results      CalculatedResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeasurementRecord {
  id           String     @id @default(uuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  definitionId String
  definition   MeasurementDefinition @relation(fields: [definitionId], references: [id])

  numericValue   Float?
  stringValue    String?
  metadataAsJson Json?

  measuredBy String?
  deviceUsed String?

  @@unique([assessmentId, definitionId])
}

// ----------------------------------------------------------------------
// 3. CAPA DE RESULTADOS
// ----------------------------------------------------------------------

enum ResultStatus {
  CALCULATED
  MISSING_DATA
  NOT_APPLICABLE
  PENDING_RULE
}

model CalculatedResult {
  id           String     @id @default(uuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  metricId String
  metric   MetricDefinition @relation(fields: [metricId], references: [id])

  numericValue   Float?
  stringValue    String?
  metadataAsJson Json?

  status ResultStatus @default(CALCULATED)

  statusCode  String?
  statusLabel String?

  formulaUsed      String?
  formulaVersion   String?
  referenceTableId String?
  engineVersion    String?

  @@unique([assessmentId, metricId])
}
